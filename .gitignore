# --- Bitrix webroot: трекаем только свой код ---
# Ядро (/bitrix/), /upload/ и служебные файлы дистрибутива восстанавливаются
# установкой и не принадлежат репозиторию.
bitrixdock/www/*
!bitrixdock/www/local/
!bitrixdock/www/index.php
!bitrixdock/www/urlrewrite.php

# Копия данных миграции (канонический источник — assets-src/)
bitrixdock/www/local/php_interface/migrations/data/

# --- Секреты и локальное окружение ---
bitrixdock/.env

# --- Логи и рантайм ---
bitrixdock/logs/

# --- macOS ---
.DS_Store
